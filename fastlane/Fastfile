default_platform(:ios)

require "fileutils" # FileUtils.mkdir_p in the deliver lane (don't rely on transitive requires)
require_relative "changelog_formatter"
require_relative "coverage_gate"
require_relative "deliver_options"
require_relative "deliver_release_notes"
require_relative "release_plan"
require_relative "version_bumper"

# match storage repo (Matchfile isn't imported via import_from_git, so set it here).
MATCH_GIT_URL = ENV["MATCH_GIT_URL"] || "git@github.com:cakuki/ios-signing.git"

def asc_api_key
  app_store_connect_api_key(
    key_id:                ENV.fetch("ASC_KEY_ID"),
    issuer_id:             ENV.fetch("ASC_ISSUER_ID"),
    key_content:           ENV.fetch("ASC_KEY_P8_BASE64"),
    is_key_content_base64: true,
    in_house:              false
  )
end

platform :ios do
  desc "Run unit tests on a simulator, then gate on line coverage (MIN_COVERAGE %)"
  lane :test do
    # Collect coverage into a known result bundle so we can read xccov afterwards.
    # `result_bundle: true` + an explicit `output_directory` emit a `.xcresult`
    # under that directory, making it locatable regardless of scan's default
    # derived-data layout.
    result_dir = ENV["TEST_OUTPUT_DIR"] || "./build"
    run_tests(project: ENV.fetch("XCODEPROJ"), scheme: ENV.fetch("SCHEME"),
              device: ENV["TEST_DEVICE"] || "iPhone 16",
              code_coverage: true, result_bundle: true,
              output_directory: result_dir)

    enforce_coverage_gate(result_dir)
  end

  desc "Sync signing assets (read-only on CI)"
  lane :sync_signing do |o|
    setup_ci
    match(type: o[:type] || "appstore", readonly: is_ci, api_key: asc_api_key,
          app_identifier: ENV.fetch("APP_IDENTIFIER"), git_url: MATCH_GIT_URL)
  end

  desc "Cut a release: regen CHANGELOG.md, bump MARKETING_VERSION (semver), tag v<semver>"
  lane :prepare_release do
    # Resolve the last `v*` release tag REACHABLE FROM HEAD (empty on the very
    # first release) and the commit subjects since it. The pure ReleasePlan turns
    # those into the cog range, the next semver, and the v<semver> tag —
    # VersionBumper does the actual level->bump (reused, not re-implemented here).
    #
    # Use `git describe --tags --abbrev=0` (NOT `git tag --list --sort`): the
    # latter picks the highest `v*` tag anywhere in the repo even if it's on an
    # unrelated branch and NOT an ancestor of HEAD, which would yield the wrong
    # changelog range and baseline version. `describe` walks back from HEAD and
    # returns the nearest *reachable* tag. `--abbrev=0` gives the bare tag name
    # (no `-<n>-g<sha>` suffix); `--match 'v*'` restricts to release tags.
    # On the first release there is no reachable tag, so `describe` exits non-zero
    # — `error_callback` swallows that into an empty string (handled downstream).
    last_tag = sh(
      ["git", "describe", "--tags", "--abbrev=0", "--match", "v*", "HEAD"],
      log: false,
      error_callback: ->(_) {}
    ).to_s.strip
    range    = ReleasePlan.changelog_range(last_tag)
    subjects = sh(["git", "log", "--no-merges", "--format=%s", range], log: false)
               .split("\n").map(&:strip).reject(&:empty?)

    plan = ReleasePlan.plan(last_tag: last_tag.empty? ? nil : last_tag, subjects: subjects)
    unless plan[:release?]
      UI.important("No releasing commits since #{last_tag.empty? ? 'init' : last_tag}; nothing to cut.")
      next
    end

    version = plan[:next_version]
    tag     = plan[:tag]
    UI.message("Cutting #{tag} (was #{plan[:current_version]}) over range #{plan[:range]}")

    # 1) Regenerate CHANGELOG.md: prepend the dated section for this range. cog's
    #    cog.toml drives the section format; pinned cog version is set by CI.
    #    Capture cog's output directly (no temp file) to avoid CWD path mismatches:
    #    fastlane runs from `fastlane/`, so the repo lives one level up (`../`).
    new_section = sh(["cog", "changelog", plan[:range]], log: false)
    existing    = File.exist?("../CHANGELOG.md") ? File.read("../CHANGELOG.md") : ""
    File.write("../CHANGELOG.md", "#{new_section.strip}\n\n#{existing}".strip + "\n")

    # 2) Bump MARKETING_VERSION (semver) in the app's xcodegen project.yml via the
    #    pure rewriter. CURRENT_PROJECT_VERSION is intentionally NOT touched — it
    #    stays the stateless TestFlight-latest+1 injected by `beta` via xcargs.
    project_yml = ENV["PROJECT_YML"] || "project.yml"
    path = "../#{project_yml}"
    # Fail fast: the v<semver> tag is meaningless without the matching
    # MARKETING_VERSION bump it's supposed to pair with. If project.yml is
    # missing we must NOT proceed to commit + tag (that would create a tag with
    # no version bump and break the tag/version coupling consumers rely on).
    UI.user_error!(
      "#{project_yml} not found at repo root; cannot bump MARKETING_VERSION. " \
      "Set PROJECT_YML / project-yml to the correct path. Aborting before commit+tag."
    ) unless File.exist?(path)
    rewritten = VersionBumper.set_marketing_version(File.read(path), version)
    # Fail fast on the silent no-op: set_marketing_version is a gsub, so a
    # missing/misspelled MARKETING_VERSION key leaves the content unchanged and
    # the bump never happens. Verify the rewritten content genuinely carries
    # `MARKETING_VERSION: "<version>"` BEFORE we write/commit/tag — otherwise the
    # v<semver> tag would pair with no version bump.
    UI.user_error!(
      "MARKETING_VERSION was not bumped to #{version} in #{project_yml}: no " \
      "`MARKETING_VERSION:` key found (missing or misspelled), so the rewrite " \
      "was a no-op. Aborting before commit+tag to avoid tagging without a bump."
    ) unless VersionBumper.marketing_version_set?(rewritten, version)
    File.write(path, rewritten)

    # 3) Commit the regen + bump, create the v<semver> tag. The tag push triggers
    #    the `beta` lane (see apple-release.yml `on: push: tags: ['v*']`). All git
    #    ops run with `-C ..` (repo root) so they match the `../`-relative files
    #    written above — the files were modified at the repo root, so staging them
    #    from `fastlane/` would silently stage nothing and tag the wrong commit.
    # Stage only the paths we touched (CHANGELOG.md + project.yml). project.yml is
    # guaranteed to exist here — `prepare_release` already `UI.user_error!`s above
    # if it's missing — so no existence guard is needed. Both paths are
    # repo-root-relative; build the list in Ruby (no shell).
    add_paths = ["CHANGELOG.md", project_yml]
    sh(["git", "-C", "..", "add", "-A", "--"] + add_paths)

    # Decide the no-op case from the INDEX for *only* the intended paths, not the
    # whole worktree: `status --porcelain` is non-empty for any untracked/unstaged
    # file, so it would wrongly "see" changes that aren't ours (and miss the real
    # question). `diff --cached --quiet -- <paths>` exits 0 iff nothing is staged
    # for those paths -> genuine no-op, skip commit+tag; exit 1 -> staged, commit.
    # Any *other* commit failure (identity, hooks, permissions) still raises and
    # stops the lane before tagging, so `beta` never fires from a tag missing the
    # changelog/bump.
    nothing_staged = system(
      "git", "-C", "..", "diff", "--cached", "--quiet", "--",
      "CHANGELOG.md", project_yml
    )
    if nothing_staged
      UI.important("No changelog/version changes staged for #{tag}; skipping commit + tag.")
      next
    end

    sh(["git", "-C", "..", "commit", "-m", "chore(release): #{tag}"])
    sh(["git", "-C", "..", "tag", tag])
    UI.success("Prepared #{tag} (commit + tag created). In CI the release " \
               "workflow pushes the commit + tag next, which triggers beta; " \
               "running locally, push the tag yourself to trigger beta.")
  end

  desc "Upload localized App Store metadata from fastlane/metadata/ (metadata-only, verify-only by default)"
  lane :deliver do
    # Metadata-only and NON-LIVE by default. DeliverOptions.build is pure +
    # unit-tested (see test/deliver_lane_test.rb): it sets verify_only unless the
    # caller opts in with DELIVER_SUBMIT=true, so CI validates the listing against
    # ASC but never mutates the store implicitly (AC2 / owner-gated slice 4). The
    # api_key is the only piece built here, from the live asc_api_key helper, and
    # merged in — keeping every other option fastlane-free and testable.
    setup_ci # non-interactive CI keychain/config, consistent with sync_signing/beta
    opts = DeliverOptions.build(ENV)

    # OPT-IN (slice 2): source the default locale's release notes from the
    # generated CHANGELOG.md instead of its hand-written release_notes.txt. OFF by
    # default (RELEASE_NOTES_FROM_CHANGELOG unset/!="true") so hand-written store
    # copy is NEVER silently clobbered. The pure DeliverReleaseNotes (unit-tested,
    # fastlane-free) decides enabled?/locale/notes/target_path; the lane owns just
    # this single write, of the same `../CHANGELOG.md` notes that `beta` ships.
    if DeliverReleaseNotes.enabled?(ENV)
      locale = DeliverReleaseNotes.default_locale(ENV)
      notes  = DeliverReleaseNotes.from_file("../CHANGELOG.md")
      target = DeliverReleaseNotes.target_path(opts[:metadata_path], locale)
      FileUtils.mkdir_p(File.dirname(target))
      File.write(target, "#{notes}\n")
      # Note: notes may be the "Automated build" fallback if CHANGELOG.md is
      # missing/empty — so phrase this as the write that happened, not a guarantee
      # the text came from the changelog.
      UI.message("Wrote #{locale} release notes (from CHANGELOG.md or fallback) -> #{target}")
    end

    upload_to_app_store(**opts.merge(api_key: asc_api_key))
  end

  desc "Build + upload to TestFlight"
  lane :beta do
    key = asc_api_key
    setup_ci
    app_id = ENV.fetch("APP_IDENTIFIER")

    # Install the match-managed distribution cert + appstore profile (readonly on CI).
    match(type: "appstore", readonly: is_ci, api_key: key, app_identifier: app_id,
          git_url: MATCH_GIT_URL)
    profile = ENV["sigh_#{app_id}_appstore_profile-name"] || "match AppStore #{app_id}"

    # CI runners can't use Xcode automatic signing (no portal session), so switch the
    # project to manual signing against the match profile before archiving.
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  ENV.fetch("XCODEPROJ"),
      code_sign_identity:    "Apple Distribution",
      profile_name:          profile
    )

    # Stateless, monotonic build number = latest TestFlight build + 1. Injected at
    # build time via xcargs so we don't depend on agvtool / project versioning config.
    build = latest_testflight_build_number(api_key: key, initial_build_number: 0,
                                           app_identifier: app_id) + 1

    gym(
      project:          ENV.fetch("XCODEPROJ"),
      scheme:           ENV.fetch("SCHEME"),
      export_method:    "app-store",
      output_directory: "./build",
      clean:            true,
      xcargs:           "CURRENT_PROJECT_VERSION=#{build}",
      export_options:   { provisioningProfiles: { app_id => profile } }
    )

    pilot(
      api_key:                           key,
      app_identifier:                    app_id,
      skip_waiting_for_build_processing: true,
      changelog: changelog_from_md
    )
  end
end

# Top CHANGELOG.md section -> clean TestFlight notes (or "Automated build").
# Logic lives in changelog_formatter.rb so it's unit-tested without fastlane.
def changelog_from_md
  ChangelogFormatter.from_file("../CHANGELOG.md")
end

# Code-coverage threshold gate for the `test` lane (EPIC-05 s2, cakuki/atelier#60).
#
# Reads MIN_COVERAGE as a PERCENTAGE (0-100). Default 0 => NON-ENFORCING: the
# gate computes and prints coverage but never fails the lane, so existing
# consuming-app CI keeps passing. Only a positive MIN_COVERAGE enforces, failing
# the lane (via UI.user_error!) when actual coverage < required, printing both
# the actual % and the required %. Pure parsing/compare logic lives in
# coverage_gate.rb so it's unit-tested without fastlane.
def enforce_coverage_gate(result_dir)
  # Parse MIN_COVERAGE strictly: unset defaults to "0" (non-enforcing), but a
  # malformed value (e.g. "abc") must fail fast rather than silently becoming
  # 0.0 via #to_f and disabling the gate, which would hide misconfiguration.
  raw = ENV.fetch("MIN_COVERAGE", "0")
  min =
    begin
      Float(raw)
    rescue ArgumentError, TypeError
      UI.user_error!("MIN_COVERAGE must be a number (0-100); got: #{raw.inspect}")
    end

  # Strict-parse rejects "abc" but not range/finiteness: a bare -1/200/NaN/Inf
  # would silently disable (NaN/negative via #positive?), always-fail (200), or
  # confuse (Infinity). Fail fast with a clear message. (Belt-and-suspenders with
  # CoverageGate.check, which also self-validates for direct callers.)
  unless min.finite? && min >= 0 && min <= 100
    UI.user_error!("MIN_COVERAGE must be a number in 0-100; got: #{raw.inspect}")
  end

  enforcing = min.positive?

  # scan writes the result bundle under output_directory; glob for the .xcresult
  # (recursive fallback) rather than hard-coding scan's exact bundle filename.
  # Pick the MOST RECENTLY MODIFIED bundle: if a prior run left an older
  # .xcresult behind, a lexicographic `.first` could measure the stale one.
  xcresult = (Dir["#{result_dir}/*.xcresult"] + Dir["#{result_dir}/**/*.xcresult"])
             .uniq.max_by { |f| File.mtime(f) }
  unless xcresult
    # No bundle means no coverage data. Don't silently let a positive gate pass —
    # and make the log reflect whether we're failing (enforcing) or skipping.
    if enforcing
      UI.user_error!("Coverage gate: no .xcresult found under #{result_dir}; cannot verify MIN_COVERAGE — failing.")
    else
      UI.important("Coverage gate: no .xcresult found under #{result_dir}; skipping (MIN_COVERAGE=0, non-enforcing).")
    end
    return
  end

  # Shell out to xccov for the JSON report (portable: no BSD-only shell flags).
  # A report we can't read/parse can't prove the bar is met — so fail only when
  # ENFORCING. In non-enforcing mode (MIN_COVERAGE=0) this is informational and
  # must NEVER fail the lane. Rescue StandardError (not just CoverageGate::Error):
  # `sh` itself can raise a fastlane/shell error (missing Xcode tools, corrupted
  # .xcresult), and non-enforcing mode must swallow those too. Include the
  # exception CLASS in the message so the underlying cause is debuggable.
  begin
    json   = sh(["xcrun", "xccov", "view", "--report", "--json", xcresult], log: false)
    result = CoverageGate.check(json, min)
  rescue StandardError => e
    msg = "Coverage gate: could not evaluate coverage (#{e.class}: #{e.message})."
    enforcing ? UI.user_error!(msg) : UI.important(msg)
    return
  end

  # 4 decimals so a near-miss (e.g. 79.9950% vs 80.0000%) doesn't display as a
  # confusing "80.00% < 80.00%" — the comparison itself is on the exact Floats.
  actual_str = format("%.4f%%", result.actual_percent)
  unless enforcing
    UI.message("Coverage: #{actual_str} (MIN_COVERAGE=0, gate non-enforcing).")
    return
  end

  required_str = format("%.4f%%", result.required_percent)
  if result.passed
    UI.success("Coverage gate passed: #{actual_str} >= required #{required_str}.")
  else
    UI.user_error!("Coverage gate FAILED: actual #{actual_str} < required #{required_str}.")
  end
end
