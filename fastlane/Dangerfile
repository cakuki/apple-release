# Shared Dangerfile (EPIC-05 slice 3, cakuki/atelier#5) — PR-level nudges for
# every consuming Apple app, run by the reusable `.github/workflows/danger.yml`
# (`workflow_call`). That workflow checks THIS repo out into `.danger-platform/`
# and invokes it as `--dangerfile=.danger-platform/fastlane/Dangerfile` (so the
# caller's PR is checked against the platform's rules, not the caller's own file).
# Lives under `fastlane/` because this platform roots its Ruby tooling there
# (Fastfile, coverage_gate.rb, changelog_formatter.rb) — keeping the Dangerfile
# beside them matches the established layout and the bundler setup. Danger's
# default lookup is the repo ROOT, so the workflow points at this path
# EXPLICITLY with `--dangerfile`; it is not auto-discovered here.
#
# Philosophy: these are LIGHTWEIGHT, NON-BLOCKING nudges (`warn`, never `fail`).
# The hard bars live elsewhere — SwiftLint/SwiftFormat (quality-gates.yml) and
# the coverage gate (Fastfile `test` lane). Conventional Commits are enforced by
# commit-lint.yml and the changelog is generated by cog, so this file does NOT
# re-check commit style or changelog presence — that would just be noise.
#
# This file is THIN GLUE on purpose: the rule logic (big-PR threshold, Swift
# source-vs-test classification) lives as PURE, unit-tested predicates in
# `fastlane/danger_rules.rb` (see `test/danger_rules_test.rb`). Here we only
# pull the diff/PR facts from the Danger DSL (`git.*`, `github.*`) and pass them
# to those functions. Thresholds are constants up top so they're trivial to tune.

require_relative "danger_rules"

# --- Tunables -----------------------------------------------------------------

# A PR touching more than this many lines (additions + deletions) gets a
# split-it-up nudge. Big PRs are harder to review well; this is a gentle prod,
# not a wall.
BIG_PR_LINES = 500

# --- Rules --------------------------------------------------------------------

# 1) Large PR → nudge to split.
# Total churn (additions + deletions). NOT `git.lines_of_code`, which is the NET
# delta (insertions - deletions) — that would let a big 800-add/800-delete PR
# read as ~0 and never warn.
changed_lines = git.insertions + git.deletions
if DangerRules.big_pr?(changed_lines, BIG_PR_LINES)
  warn(
    "This PR changes #{changed_lines} lines (over #{BIG_PR_LINES}). " \
    "Consider splitting it into smaller, focused PRs — they're easier and " \
    "safer to review."
  )
end

# 2) Swift sources changed but no test files touched → missing-tests nudge.
# Include deleted files too: deleting a *Tests* file IS touching tests, and must
# not trip the "no tests touched" warning.
touched = (git.modified_files + git.added_files + git.deleted_files).uniq
swift_sources = DangerRules.swift_sources(touched)
test_files = DangerRules.test_files(touched)
if DangerRules.missing_tests?(swift_sources, test_files)
  warn(
    "Swift sources changed but no test files (`*Tests*`) were touched. " \
    "Consider adding or updating tests for these changes."
  )
end

# 3) Empty PR description → nudge to explain the change.
if github.pr_body.to_s.strip.empty?
  warn(
    "This PR has no description. A short summary of what changed and why " \
    "helps reviewers (and future you)."
  )
end
